# AD-2: these are two different connections, not two names for one.
# Runtime uses the transaction pooler (:6543) — no prepared statements.
# Migrations use the session pooler (:5432) — DDL requires them.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# openssl rand -hex 32
PAYLOAD_SECRET=

# AD-3: opt-in to Drizzle schema push (dev only). Leave unset — set to 1 only
# against a local/test DB you can afford to have auto-synced; never a shared one.
PAYLOAD_PUSH=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional mail. Without these, leads are still persisted, but each one
# records that no notification was sent. See AD-8.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Supabase Storage (S3-compatible). Optional until media upload is wired.
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# AD-12: a GTM container id (GTM-XXXX), not a GA4 measurement id.
# Unset means no tag surface at all. Tags never fire before consent.
NEXT_PUBLIC_GTM_ID=
